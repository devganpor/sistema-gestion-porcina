# Configuración de Base de Datos (Railway PostgreSQL)
DATABASE_URL=postgresql://usuario:password@host:puerto/database

# Configuración local (SQLite - solo desarrollo)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gestion_porcina
DB_USER=postgres
DB_PASSWORD=tu_password

# Configuración JWT
JWT_SECRET=tu_clave_secreta_muy_segura_de_32_caracteres_minimo

# Puerto del servidor
PORT=3001

# Entorno
NODE_ENV=production

# Configuración de Email (SendGrid)
SENDGRID_API_KEY=SG.tu_sendgrid_api_key
EMAIL_FROM=tu_email@dominio.com
EMAIL_FROM_NAME=Sistema Gestión Porcina

# URL del Frontend
FRONTEND_URL=https://tu-dominio-frontend.railway.app

# Configuración de Sesión
SESSION_SECRET=otra_clave_diferente_para_sesiones

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# Backup
BACKUP_ENABLED=true
MAX_BACKUPS=30