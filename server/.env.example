# Configuración de Base de Datos
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gestion_porcina
DB_USER=postgres
DB_PASSWORD=tu_password

# Configuración JWT
JWT_SECRET=tu_clave_secreta_muy_segura_aqui_minimo_32_caracteres

# Configuración de Sesiones
SESSION_SECRET=tu_clave_secreta_para_sesiones_diferente_al_jwt

# Puerto del servidor
PORT=3001

# Entorno
NODE_ENV=development

# URL del Frontend (para CORS)
FRONTEND_URL=http://localhost:3000

# Configuración de Usuario Administrador
ADMIN_EMAIL=admin@granja.com
ADMIN_PASSWORD=admin123

# Configuración de Backups
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
MAX_BACKUPS=30

# Configuración de Logs
LOG_LEVEL=info
LOG_ROTATION=true

# Configuración de Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=5

# Configuración de Archivos
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Configuración de Email (opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASS=tu_password_de_aplicacion
FROM_EMAIL=noreply@granja.com